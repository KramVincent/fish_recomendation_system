{
  "name": "fish-diet-recommendation",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names frontend,backend --prefix-colors cyan,yellow \"vite\" \"cd ../backend && python main.py\"",
    "dev:frontend": "vite",
    "dev:backend": "cd ../backend && python main.py",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write src/",
    "mobile:init": "npx cap init",
    "mobile:add-android": "npx cap add android",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:open-android": "npx cap open android",
    "mobile:build-apk": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "mobile:build-release": "npm run build && npx cap sync android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@headlessui/vue": "^1.7.22",
    "@heroicons/vue": "^2.1.5",
    "@supabase/supabase-js": "^2.95.3",
    "@vueuse/core": "^11.0.0",
    "axios": "^1.7.4",
    "chart.js": "^4.4.4",
    "pinia": "^3.0.1",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.0",
    "vue-chartjs": "^5.3.1",
    "vue-router": "^4.4.3",
    "vue3-toastify": "^0.2.3"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^22.5.0",
    "@vitejs/plugin-vue": "^5.1.3",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.44",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^6.4.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.1.4"
  }
}
