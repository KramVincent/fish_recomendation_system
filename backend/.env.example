DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin
DB_NAME=fish_db
# Prefer DATABASE_URL in production (Render/Neon)
# DATABASE_URL=postgresql://user:password@host:5432/fish_db

# Comma-separated allowed frontend origins for CORS
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app

# Public backend URL used to build absolute upload links
# PUBLIC_BASE_URL=https://your-backend.onrender.com

# Optional custom directories
# UPLOADS_DIR=/var/data/uploads
# MODEL_DIR=/opt/render/project/src/backend/models
